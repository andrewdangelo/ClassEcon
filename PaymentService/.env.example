# Server Configuration
PORT=4003
NODE_ENV=development
BILLING_MODE=stripe

# MongoDB
MONGODB_URI=mongodb://localhost:27017/classecon-payments

# Stripe Configuration
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key_here
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret_here

# Stripe Price IDs (from Stripe Dashboard)
STRIPE_PRICE_STARTER_MONTHLY=price_starter_monthly_id
STRIPE_PRICE_STARTER_YEARLY=price_starter_yearly_id
STRIPE_PRICE_PROFESSIONAL_MONTHLY=price_professional_monthly_id
STRIPE_PRICE_PROFESSIONAL_YEARLY=price_professional_yearly_id

# URLs
FRONTEND_URL=http://localhost:3000
BACKEND_URL=http://localhost:4000

# Authentication
JWT_SECRET=your-jwt-secret-key-here
INTERNAL_API_KEY=your-internal-api-key-for-service-to-service-auth
SERVICE_API_KEY=your-service-api-key-for-backend-to-call-payment-service

# CORS
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173
