{
  "$schema": "https://unpkg.com/wrangler/config-schema.json",
  "name": "classecon-admin",
  "compatibility_date": "2026-04-21",
  "observability": { "enabled": true },
  "workers_dev": true,
  "preview_urls": true,
  "routes": [
    { "pattern": "admin.classecon.net", "custom_domain": true }
  ],
  "assets": {
    "directory": "../../admin/dist",
    "not_found_handling": "single-page-application"
  },
  "env": {
    "staging": {
      "name": "classecon-admin-staging",
      "workers_dev": true,
      "preview_urls": true,
      "observability": { "enabled": true },
      "routes": [],
      "assets": {
        "directory": "../../admin/dist-staging",
        "not_found_handling": "single-page-application"
      }
    }
  }
}
