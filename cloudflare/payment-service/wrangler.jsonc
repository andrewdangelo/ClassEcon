{
  "$schema": "https://unpkg.com/wrangler/config-schema.json",
  "name": "classecon-payment",
  "main": "src/index.ts",
  "compatibility_date": "2026-04-21",
  "compatibility_flags": ["nodejs_compat"],
  "observability": { "enabled": true },
  "workers_dev": true,
  "preview_urls": true,
  "routes": [
    { "pattern": "payments.classecon.net", "custom_domain": true }
  ],
  "containers": [
    {
      "class_name": "PaymentServiceContainer",
      "image": "../../PaymentService/Dockerfile",
      "max_instances": 2,
      "instance_type": "basic"
    }
  ],
  "durable_objects": {
    "bindings": [
      { "name": "PAYMENT_CONTAINER", "class_name": "PaymentServiceContainer" }
    ]
  },
  "migrations": [
    { "tag": "v1", "new_sqlite_classes": ["PaymentServiceContainer"] }
  ],
  "env": {
    "staging": {
      "name": "classecon-payment-staging",
      "workers_dev": true,
      "preview_urls": true,
      "routes": [],
      "containers": [
        {
          "class_name": "PaymentServiceContainer",
          "image": "../../PaymentService/Dockerfile",
          "max_instances": 1,
          "instance_type": "basic"
        }
      ],
      "durable_objects": {
        "bindings": [
          { "name": "PAYMENT_CONTAINER", "class_name": "PaymentServiceContainer" }
        ]
      },
      "migrations": [
        { "tag": "v1", "new_sqlite_classes": ["PaymentServiceContainer"] }
      ]
    }
  }
}
