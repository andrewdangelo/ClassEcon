{
  "name": "email-service",
  "version": "1.0.0",
  "description": "Production-grade Email Service microservice with GraphQL API and Resend integration",
  "main": "dist/server/index.js",
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only src/server/index.ts",
    "dev:worker": "ts-node-dev --respawn --transpile-only src/worker/index.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/server/index.js",
    "worker": "node dist/worker/index.js",
    "lint": "eslint src --ext .ts",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "email",
    "microservice",
    "graphql",
    "resend",
    "mongodb"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@apollo/server": "^4.11.0",
    "@graphql-tools/load-files": "^7.0.0",
    "@graphql-tools/merge": "^9.0.0",
    "argon2": "^0.41.1",
    "cors": "^2.8.5",
    "express": "^4.21.0",
    "graphql": "^16.9.0",
    "mongoose": "^8.7.0",
    "pino": "^9.4.0",
    "pino-pretty": "^11.2.2",
    "resend": "^4.0.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^22.7.0",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.6.2"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
