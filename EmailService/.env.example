# Required
PORT=4000
NODE_ENV=development

# MongoDB
MONGODB_URI=mongodb://localhost:27017
MONGODB_DB_NAME=email_service

# Outbound mail: set SMTP_HOST for SMTP, and/or RESEND_API_KEY for Resend.
# EMAIL_TRANSPORT=auto picks SMTP when SMTP_HOST is set, otherwise Resend.
EMAIL_TRANSPORT=auto

# --- SMTP (Nodemailer) — typical ports: 587 STARTTLS, 465 TLS ---
SMTP_HOST=localhost
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
# Set false only for dev / self-signed certs (e.g. local Mailpit)
SMTP_REJECT_UNAUTHORIZED=true

# --- Resend (optional alternative) ---
# RESEND_API_KEY=re_xxxxxxxxxxxx

FROM_EMAIL=noreply@yourdomain.com

# Application
APP_URL=http://localhost:3000

# Authentication (generate with: openssl rand -base64 32)
ADMIN_TOKEN=your-admin-token-min-32-chars-here
SERVICE_TOKEN=your-service-token-min-32-chars-here
WEBHOOK_SECRET=your-webhook-secret-16chars

# HMAC secret for unsubscribe tokens (optional, falls back to SERVICE_TOKEN)
UNSUBSCRIBE_HMAC_SECRET=your-hmac-secret-min-32-chars-here

# Worker configuration
WORKER_CONCURRENCY=5
WORKER_MAX_ATTEMPTS=5
WORKER_SENDS_PER_SECOND=10
WORKER_POLL_INTERVAL_MS=1000

# Rate limiting
RATE_LIMIT_2FA_PER_EMAIL_HOUR=5
RATE_LIMIT_2FA_PER_USER_HOUR=5
RATE_LIMIT_2FA_PER_IP_HOUR=10
RATE_LIMIT_2FA_COOLDOWN_SECONDS=60

# Token expiry
OTP_EXPIRY_MINUTES=10
RESET_TOKEN_EXPIRY_MINUTES=60

# Allowed redirect origins for password reset (comma-separated)
ALLOWED_REDIRECT_ORIGINS=http://localhost:3000,https://yourdomain.com
