# Server Configuration
PORT=4000

# CORS Configuration
# Comma-separated list of allowed origins
CORS_ORIGINS=http://localhost:5173,http://localhost:5174,http://localhost:3000
# Legacy single origin (kept for backwards compatibility)
CORS_ORIGIN=http://localhost:5173

# Frontend URLs
FRONTEND_URL=http://localhost:5173
LANDING_PAGE_URL=http://localhost:5174

# JWT Configuration (Legacy - can be removed after full migration)
JWT_SECRET=your-jwt-secret-key-here
JWT_EXPIRES_IN=15m
REFRESH_JWT_SECRET=your-refresh-jwt-secret-key-here
REFRESH_JWT_EXPIRES_IN=7d

# Auth Service Configuration
AUTH_SERVICE_URL=http://localhost:4001
SERVICE_API_KEY=your-service-api-key-here

# Payment Service Configuration
# Backend proxies payment requests to PaymentService
PAYMENT_SERVICE_URL=http://localhost:4003
PAYMENT_SERVICE_API_KEY=your-payment-service-api-key-here

# Email microservice (GraphQL on PORT from EmailService, e.g. 4004)
EMAIL_SERVICE_URL=http://localhost:4004
EMAIL_SERVICE_TOKEN=your-32-plus-character-service-token-matching-email-service

# Stripe (required by scripts/sync-stripe-subscription.ts and payment flows)
STRIPE_SECRET_KEY=sk_test_your_key_here

# Database
DATABASE_URL=mongodb://localhost:27017/classecon

# Node Environment
NODE_ENV=development
